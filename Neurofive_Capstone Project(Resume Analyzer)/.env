# Rename this file to ".env" and fill in your real key.

# Your BlueMinds API key (get one at https://api.bluesminds.com)
BLUESMINDS_API_KEY=sk-Enter your API key here

# BlueMinds is OpenAI-compatible — you normally won't need to change these.
BLUESMINDS_BASE_URL=https://api.bluesminds.com/v1
BLUESMINDS_MODEL=gpt-4o

# Local server settings
PORT=5000
FLASK_DEBUG=true
